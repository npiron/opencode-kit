# API Keys for opencode
# Copy to ~/.config/opencode/.env and fill in your keys.

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI (GPT)
OPENAI_API_KEY=sk-your-key-here

# Google Gemini
GEMINI_API_KEY=your-key-here

# DeepSeek (via opencode-go provider)
DEEPSEEK_API_KEY=sk-your-key-here
