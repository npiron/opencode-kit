{
  "$schema": "https://opencode.ai/config.json",
  "data": {
    "directory": ".opencode"
  },
  "provider": {
    "anthropic": {
      "apiKey": "{env:ANTHROPIC_API_KEY}"
    },
    "openai": {
      "apiKey": "{env:OPENAI_API_KEY}",
      "disabled": true
    },
    "google": {
      "apiKey": "{env:GEMINI_API_KEY}",
      "disabled": true
    },
    "opencode-go": {
      "apiKey": "{env:DEEPSEEK_API_KEY}"
    }
  },
  "agent": {
    "heartbeat": {
      "mode": "all",
      "model": "deepseek/deepseek-v4-pro",
      "description": "Agent Pouls — heartbeat autonome toutes les heures"
    }
  },
  "plugin": [
    "opencode-tasks"
  ],
  "shell": {
    "path": "/bin/zsh",
    "args": ["-l"]
  },
  "mcp": {},
  "autoCompact": true,
  "debug": false
}
